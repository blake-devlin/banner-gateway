# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit it.

# Port the Node server listens on.
# Use 8080 when running behind nginx; use 80 only if binding directly (needs root).
PORT=8080

# Interface to bind. 0.0.0.0 = all interfaces; 127.0.0.1 = loopback only (use with nginx).
HOST=0.0.0.0

# Public-facing base URL shown in the home page UI and log output.
# Set this to your server's domain or IP, e.g. http://192.168.1.50:8080
PUBLIC_BASE_URL=http://YOUR_SERVER_IP_OR_DOMAIN:8080

# Path to the SQLite database file (created automatically on first run).
DB_PATH=./data/dxm_ingest.sqlite

# Directory for daily JSONL log files.
LOG_DIR=./logs

# Maximum incoming body size. Default 1mb — increase if the DXM sends large payloads.
MAX_BODY_SIZE=1mb

# Optional shared secret. If set, every push must include the header:
#   X-DXM-Secret: <value>
# Leave commented out for initial testing (all pushes accepted without auth).
# Configure the DXM700 custom HTTP headers to include this header.
# DXM_SHARED_SECRET=change-me-before-production

# Runtime environment (development | production)
NODE_ENV=development
